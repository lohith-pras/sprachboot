# SprachBoot — Environment Variables
#
# You normally DON'T need to edit this. API keys are entered in the app's
# onboarding screen on first launch and stored locally in backend/api_keys.json.
# The values below are only fallbacks / non-key config.

# OpenRouter — conversation (Llama) + error analysis (DeepSeek).
# Optional here: the onboarding screen sets this for you.
OPENROUTER_API_KEY=sk-or-...

# DeepL — optional, only adds tap-to-translate. Set via onboarding too.
# DEEPL_API_KEY=...

# Database (SQLite locally; a Postgres URL would override it).
DATABASE_URL=sqlite:///./sprachboot.db

# ChromaDB persistence directory (local semantic memory).
CHROMA_PERSIST_DIR=./chroma_db

# Frontend → Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
