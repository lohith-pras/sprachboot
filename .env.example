# SprachBoot — Environment Variables
# Copy to .env (backend) and frontend/.env.local (frontend)

# OpenRouter — Gemma (conversation) + DeepSeek (error analysis)
OPENROUTER_API_KEY=sk-or-...

# OpenAI — Whisper STT + text-embedding-3-small (Phase 3)
OPENAI_API_KEY=sk-...

# Database (SQLite in dev, Postgres URL in prod)
DATABASE_URL=sqlite:///./sprachboot.db

# ChromaDB (Phase 3)
CHROMA_PERSIST_DIR=./chroma_db

# Frontend → Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
