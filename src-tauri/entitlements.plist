<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    The app is signed ad-hoc (no Apple Developer ID). It bundles a PyInstaller
    sidecar whose Python.framework is signed by python.org with a different
    Team ID. Under the hardened runtime, Library Validation would reject loading
    that framework ("different Team IDs"), crashing the backend at startup.
    Disabling library validation lets the ad-hoc app load the third-party-signed
    framework. Allow-unsigned-executable-memory / allow-jit cover CPython's
    runtime needs.
  -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
</dict>
</plist>
